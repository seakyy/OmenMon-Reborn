<?xml version="1.0" encoding="utf-8"?>
<OmenMon>
    <!--
      //\\   OmenMon: Hardware Monitoring & Control Utility
     //  \\  Configuration Settings XML File
         //  https://omenmon.github.io/
    -->
    <!-- Note: comments under child nodes such as <ColorPresets> and <FanPrograms>
         will be overwritten when the file is automatically generated upon save -->
    <Config>
        <!-- Automatically apply settings on start -->
        <AutoConfig>false</AutoConfig>
        <!-- Automatically start up with Windows -->
        <AutoStartup>true</AutoStartup>
        <!-- Ignore BIOS errors if false (for not fully compatible devices) -->
        <BiosErrorReporting>true</BiosErrorReporting>
        <!-- Pause BIOS heartbeat while on battery to prevent forced hibernation (default: true) -->
        <BiosHeartbeatPauseOnBattery>true</BiosHeartbeatPauseOnBattery>
        <!-- Display temperatures in Fahrenheit instead of Celsius (default: false) -->
        <TemperatureUseFahrenheit>false</TemperatureUseFahrenheit>
        <!-- Thermal Panic Mode: force max fans + balloon alert when temperature threshold is reached -->
        <!-- REQUIRES GuiDynamicIcon=true. Set to true only after verifying your sensors report realistic values. -->
        <ThermalPanicEnabled>false</ThermalPanicEnabled>
        <ThermalPanicTemperature>90</ThermalPanicTemperature>
        <ThermalPanicHysteresis>5</ThermalPanicHysteresis>
        <!-- Color Backlight -->
        <!-- Note: two default entries are hard-coded in the application
             and will appear if there is nothing else to show instead -->
        <ColorPresets>
            <Preset Name="All Amber">FF8800:FF8800:FF8800:FF8800</Preset>
            <Preset Name="All White">FFFFFF:FFFFFF:FFFFFF:FFFFFF</Preset>
            <Preset Name="Cyan Magenta Yellow">FFFF00:FF0080:3AE5E7:FFFF00</Preset>
            <Preset Name="DefaultApp">0080FF:00FF00:00FF00:FFFFFF</Preset>
            <Preset Name="DefaultOem">0F84FA:710FFA:F9350F:FAAC0F</Preset>
            <Preset Name="Red Green Blue">0000FF:00FF00:FF0000:FFFFFF</Preset>
        </ColorPresets>
        <!-- Embedded Controller -->
        <!-- Maximum number of failed attempts waiting to read -->
        <EcFailLimit>15</EcFailLimit>
        <!-- Embedded Controller monitoring interval [ms]
             (applies to command-line mode -EcMon context) -->
        <EcMonInterval>1000</EcMonInterval>
        <!-- How long before bailing out trying to get a mutex [ms] -->
        <EcMutexTimeout>200</EcMutexTimeout>
        <!-- Maximum number of read or write attempts -->
        <EcRetryLimit>3</EcRetryLimit>
        <!-- Iterations before waiting fails each time -->
        <EcWaitLimit>30</EcWaitLimit>
        <!-- Fan Control -->
        <!-- Fan countdown will always be continually extended, even
             with no fan program running, no constant-speed button
             selected, and the main window hidden, until exit -->
        <FanCountdownExtendAlways>false</FanCountdownExtendAlways>
        <!-- Fan countdown timer will be extended by this value [s] -->
        <FanCountdownExtendInterval>120</FanCountdownExtendInterval>
        <!-- Fan countdown extension threshold [s] -->
        <FanCountdownExtendThreshold>5</FanCountdownExtendThreshold>
        <!-- Minimum and maximum fan level thresholds [krpm] -->
        <FanLevelMax>55</FanLevelMax>
        <FanLevelMin>20</FanLevelMin>
        <!-- Before setting fan levels, set manual fan mode first using the Embedded Controller -->
        <FanLevelNeedManual>false</FanLevelNeedManual>
        <!-- Use the Embedded Controller instead of a BIOS call for fan-level setting -->
        <FanLevelUseEc>false</FanLevelUseEc>
        <!-- Default fan program, which might be loaded on startup (must match a <Program Name="..."> entry) -->
        <FanProgramDefault>Power</FanProgramDefault>
        <!-- Default alternate fan program to switch to if no longer on AC power -->
        <FanProgramDefaultAlt>Silent</FanProgramDefaultAlt>
        <!-- Check first (using the EC) if the fan mode is not set already -->
        <FanProgramModeCheckFirst>false</FanProgramModeCheckFirst>
        <!-- Suspend fan program whenever the system enters low-power mode -->
        <FanProgramSuspend>true</FanProgramSuspend>
        <!-- Fan program definitions
             Curve visualization: https://www.desmos.com/calculator/6vfpghtud0 -->
        <FanPrograms>
            <Program Name="Power">
                <FanMode>Performance</FanMode>
                <GpuPower>Maximum</GpuPower>
                <Level Temperature="00">
                    <Cpu>00</Cpu>
                    <Gpu>00</Gpu>
                </Level>
                <Level Temperature="36">
                    <Cpu>21</Cpu>
                    <Gpu>00</Gpu>
                </Level>
                <Level Temperature="39">
                    <Cpu>22</Cpu>
                    <Gpu>22</Gpu>
                </Level>
                <Level Temperature="42">
                    <Cpu>23</Cpu>
                    <Gpu>24</Gpu>
                </Level>
                <Level Temperature="45">
                    <Cpu>24</Cpu>
                    <Gpu>26</Gpu>
                </Level>
                <Level Temperature="48">
                    <Cpu>25</Cpu>
                    <Gpu>27</Gpu>
                </Level>
                <Level Temperature="51">
                    <Cpu>26</Cpu>
                    <Gpu>29</Gpu>
                </Level>
                <Level Temperature="54">
                    <Cpu>28</Cpu>
                    <Gpu>31</Gpu>
                </Level>
                <Level Temperature="57">
                    <Cpu>30</Cpu>
                    <Gpu>33</Gpu>
                </Level>
                <Level Temperature="60">
                    <Cpu>32</Cpu>
                    <Gpu>35</Gpu>
                </Level>
                <Level Temperature="63">
                    <Cpu>34</Cpu>
                    <Gpu>37</Gpu>
                </Level>
                <Level Temperature="66">
                    <Cpu>36</Cpu>
                    <Gpu>40</Gpu>
                </Level>
                <Level Temperature="69">
                    <Cpu>38</Cpu>
                    <Gpu>43</Gpu>
                </Level>
                <Level Temperature="72">
                    <Cpu>41</Cpu>
                    <Gpu>46</Gpu>
                </Level>
                <Level Temperature="75">
                    <Cpu>44</Cpu>
                    <Gpu>49</Gpu>
                </Level>
                <Level Temperature="78">
                    <Cpu>47</Cpu>
                    <Gpu>52</Gpu>
                </Level>
                <Level Temperature="81">
                    <Cpu>50</Cpu>
                    <Gpu>55</Gpu>
                </Level>
                <Level Temperature="84">
                    <Cpu>55</Cpu>
                    <Gpu>57</Gpu>
                </Level>
            </Program>
            <Program Name="Silent">
                <FanMode>Default</FanMode>
                <GpuPower>Minimum</GpuPower>
                <Level Temperature="00">
                    <Cpu>21</Cpu>
                    <Gpu>00</Gpu>
                </Level>
                <Level Temperature="50">
                    <Cpu>25</Cpu>
                    <Gpu>00</Gpu>
                </Level>
                <Level Temperature="55">
                    <Cpu>25</Cpu>
                    <Gpu>25</Gpu>
                </Level>
                <Level Temperature="60">
                    <Cpu>30</Cpu>
                    <Gpu>30</Gpu>
                </Level>
                <Level Temperature="65">
                    <Cpu>35</Cpu>
                    <Gpu>35</Gpu>
                </Level>
                <Level Temperature="70">
                    <Cpu>40</Cpu>
                    <Gpu>40</Gpu>
                </Level>
                <Level Temperature="75">
                    <Cpu>45</Cpu>
                    <Gpu>45</Gpu>
                </Level>
                <Level Temperature="80">
                    <Cpu>50</Cpu>
                    <Gpu>50</Gpu>
                </Level>
                <Level Temperature="85">
                    <Cpu>55</Cpu>
                    <Gpu>57</Gpu>
                </Level>
            </Program>
        </FanPrograms>
        <!-- GPU -->
        <!-- Default GPU power settings (valid values: Minimum | Medium | Maximum) -->
        <GpuPowerDefault>Maximum</GpuPowerDefault>
        <!-- The wait before setting the GPU power for the 2nd time [ms] -->
        <GpuPowerSetInterval>200</GpuPowerSetInterval>
        <!-- Graphical User Interface -->
        <GuiCloseWindowExit>false</GuiCloseWindowExit>
        <GuiDpiChangeResize>false</GuiDpiChangeResize>
        <GuiDynamicIcon>true</GuiDynamicIcon>
        <GuiDynamicIconHasBackground>true</GuiDynamicIconHasBackground>
        <GuiStayOnTop>true</GuiStayOnTop>
        <GuiSysInfoFontSize>0</GuiSysInfoFontSize>
        <GuiTipDuration>30000</GuiTipDuration>
        <!-- Omen Key -->
        <KeyCustomAction>
            <Enabled>false</Enabled>
            <ExecCmd>cmd.exe</ExecCmd>
            <ExecArgs>/c start /min "" powershell -WindowStyle Hidden (Add-Type '[DllImport(\"user32.dll\")] public static extern int SendMessage(int hWnd, int hMsg, int wParam, int lParam);' -Name User32 -PassThru)::SendMessage(-1, 0x0112, 0xF170, 2) ^| Out-Null</ExecArgs>
            <Minimized>true</Minimized>
        </KeyCustomAction>
        
        <!-- Cycle through keyboard color presets on Omen key press -->
        <!-- Takes priority over KeyToggleFanProgram and KeyCustomAction -->
        <KeyToggleColorPreset>true</KeyToggleColorPreset>
        
        <!-- Suppress the balloon tip notification when cycling presets -->
        <KeyToggleColorPresetSilent>false</KeyToggleColorPresetSilent>

        <KeyToggleFanProgram>false</KeyToggleFanProgram>
        <KeyToggleFanProgramCycleAll>true</KeyToggleFanProgramCycleAll>
        <KeyToggleFanProgramShowGuiFirst>true</KeyToggleFanProgramShowGuiFirst>
        <KeyToggleFanProgramSilent>false</KeyToggleFanProgramSilent>
        <!-- Preset Settings -->
        <PresetRefreshRateHigh>165</PresetRefreshRateHigh>
        <PresetRefreshRateLow>60</PresetRefreshRateLow>
        <!-- Temperature Sensors -->
        <!-- TNT2-TNT5 disabled: unreliable on most devices (false spikes force fans to 100%).     -->
        <!-- BIOS source enabled: on 2023+ HP OMEN/Victus devices (8BBE, 8BAB, 8C9C, …) the      -->
        <!-- EC CPUT register (0x57) overlaps with firmware string data and always returns 0xFF.   -->
        <!-- The WMI BIOS temperature (GetTemperature) is the only valid CPU-temp proxy on those  -->
        <!-- models. On older devices BIOS reads slightly lower, but max(BIOS, CPUT, GPTM) still  -->
        <!-- returns the correct maximum — enabling it here causes no regression.                  -->
        <Temperature>
            <Sensor Name="CPUT" Source="EC" />
            <Sensor Name="GPTM" Source="EC" />
            <Sensor Name="BIOS" Source="BIOS" Use="true" />
            <Sensor Name="RTMP" Source="EC" />
            <Sensor Name="TMP1" Source="EC" />
            <Sensor Name="TNT2" Source="EC" Use="false" />
            <Sensor Name="TNT3" Source="EC" Use="false" />
            <Sensor Name="TNT4" Source="EC" Use="false" />
            <Sensor Name="TNT5" Source="EC" Use="false" />
        </Temperature>
        <!-- Model Database -->
        <!-- The application reads EC register mappings from here. If a model is not listed, the Heuristic Scanner will auto-configure it. -->
        <Models>
            <Model ProductId="8A4C" DisplayName="Omen 16 (2022, i9-12900H)">
                <FanLevelReg0>52</FanLevelReg0>
                <FanLevelReg1>53</FanLevelReg1>
                <FanRateReadReg0>46</FanRateReadReg0>
                <FanRateReadReg1>47</FanRateReadReg1>
                <FanRateWriteReg0>58</FanRateWriteReg0>
                <FanRateWriteReg1>59</FanRateWriteReg1>
                <FanSpeedReg0>176</FanSpeedReg0>
                <FanSpeedReg1>178</FanSpeedReg1>
                <CountdownReg>99</CountdownReg>
                <ManualReg>98</ManualReg>
                <ModeReg>149</ModeReg>
                <SwitchReg>244</SwitchReg>
            </Model>
            <Model ProductId="8A4D" DisplayName="Omen 16 (2022, k0xxx)">
                <FanLevelReg0>52</FanLevelReg0>
                <FanLevelReg1>53</FanLevelReg1>
                <FanRateReadReg0>46</FanRateReadReg0>
                <FanRateReadReg1>47</FanRateReadReg1>
                <FanRateWriteReg0>58</FanRateWriteReg0>
                <FanRateWriteReg1>59</FanRateWriteReg1>
                <FanSpeedReg0>176</FanSpeedReg0>
                <FanSpeedReg1>178</FanSpeedReg1>
                <CountdownReg>99</CountdownReg>
                <ManualReg>98</ManualReg>
                <ModeReg>149</ModeReg>
                <SwitchReg>244</SwitchReg>
            </Model>
            <!-- 8BBE: HP Victus 16 R0053NT (2023) — fan level regs at 0x11/0x12, confirmed via probe EC[0x11]=BIOS CPU level. -->
            <!-- Manual-mode quirk (issue #19, yunusemreyl) — HYPOTHESIS, awaiting hardware confirmation:                      -->
            <!--   Re-reading all six of yunusemreyl's hardware probes pinned the manual-fan gate at EC[0x06]:                  -->
            <!--                                                                                                                -->
            <!--      Mode (BIOS profile)        EC[0x06]   EC[0x59]   Fans physical                                            -->
            <!--      Fan Max (Omen Hub)            0x08      0x30     spin to max                                              -->
            <!--      Custom Fan (Omen Hub)         0x08      0x11     manual override                                          -->
            <!--      Eco / Balanced / Auto         0x48      0x30     BIOS auto                                                -->
            <!--      Performance                   0x48      0x31     BIOS auto                                                -->
            <!--                                                                                                                -->
            <!--   So 0x59 is just the BIOS *profile* selector (Eco/Balanced=0x30, Performance=0x31, Custom=0x11), and it       -->
            <!--   doesn't actually control whether the fans honour OmenMon — Fan Max with 0x59=0x30 spins them up just fine.   -->
            <!--   The real manual gate is 0x06: 0x08 = manual override active (set in both Fan Max and Custom Fan), 0x48 =     -->
            <!--   BIOS auto control. Bit 6 (0x40) toggles between the two. The legacy OMCC at 0x62 stays at 0x16 on every      -->
            <!--   probe regardless of fan state, so the original v1.2.x ManualReg=98 never actually engaged anything here.     -->
            <!--                                                                                                                -->
            <!-- How to validate (and what to do if your fans are still locked):                                                -->
            <!--   1. Update OmenMon and reboot.                                                                                -->
            <!--   2. Open the GUI → Fan tab → toggle "Manual" on. Fans should now respond to slider input.                     -->
            <!--   3. If they don't, run `OmenMon.exe -EcMon` and verify EC[0x06] flips between 0x08 and 0x48 when you toggle   -->
            <!--      "Custom Fan" / "Auto" in Omen Gaming Hub. If it doesn't, the gate is somewhere else — please report on    -->
            <!--      issue #19 with a fresh hardware probe in each mode.                                                       -->
            <!--   4. Re-run the Auto-Calibration Wizard — once fans actually spin, the RPM tachometers will be detected.      -->
            <Model ProductId="8BBE" DisplayName="HP Victus 16 (2023, R0053NT)">
                <FanLevelReg0>17</FanLevelReg0>
                <FanLevelReg1>18</FanLevelReg1>
                <FanRateReadReg0>46</FanRateReadReg0>
                <FanRateReadReg1>47</FanRateReadReg1>
                <FanRateWriteReg0>58</FanRateWriteReg0>
                <FanRateWriteReg1>59</FanRateWriteReg1>
                <FanSpeedReg0>176</FanSpeedReg0>
                <FanSpeedReg1>178</FanSpeedReg1>
                <CountdownReg>99</CountdownReg>
                <ManualReg>6</ManualReg>
                <ManualValueOn>8</ManualValueOn>
                <ManualValueOff>72</ManualValueOff>
                <ModeReg>149</ModeReg>
                <SwitchReg>244</SwitchReg>
            </Model>
            <!-- 8BAD: HP Omen 17 (2023) — FanLevel at 0x34/0x35, confirmed via probe EC[0x34]=0x0D=CPU, EC[0x35]=0x0D=GPU (matches BIOS GetFanLevel) -->
            <Model ProductId="8BAD" DisplayName="HP Omen 17 (2023)">
                <FanLevelReg0>52</FanLevelReg0>
                <FanLevelReg1>53</FanLevelReg1>
                <FanRateReadReg0>46</FanRateReadReg0>
                <FanRateReadReg1>47</FanRateReadReg1>
                <FanRateWriteReg0>58</FanRateWriteReg0>
                <FanRateWriteReg1>59</FanRateWriteReg1>
                <FanSpeedReg0>176</FanSpeedReg0>
                <FanSpeedReg1>178</FanSpeedReg1>
                <CountdownReg>99</CountdownReg>
                <ManualReg>98</ManualReg>
                <ModeReg>149</ModeReg>
                <SwitchReg>244</SwitchReg>
            </Model>
            <!-- 8BAB: HP Omen 16 (2025) — fan level at 0x11/0x12, RPM at 0xE3/0xE5 (0xB0/0xB2 return junk >15000 on this BIOS, rejected by constraint) -->
            <Model ProductId="8BAB" DisplayName="HP Omen 16 (2025)">
                <FanLevelReg0>17</FanLevelReg0>
                <FanLevelReg1>18</FanLevelReg1>
                <FanRateReadReg0>46</FanRateReadReg0>
                <FanRateReadReg1>47</FanRateReadReg1>
                <FanRateWriteReg0>58</FanRateWriteReg0>
                <FanRateWriteReg1>59</FanRateWriteReg1>
                <FanSpeedReg0>227</FanSpeedReg0>
                <FanSpeedReg1>229</FanSpeedReg1>
                <CountdownReg>99</CountdownReg>
                <ManualReg>98</ManualReg>
                <ModeReg>149</ModeReg>
                <SwitchReg>244</SwitchReg>
            </Model>
            <!-- 8A25: HP Victus 16-d1xxx (2022, 12th gen Intel) — GetMaxFan=True sets 0xFF at 0x34/0x35; rate regs confirmed at 0x2E/0x2F; Fan2=Unsupported -->
            <Model ProductId="8A25" DisplayName="HP Victus 16 (2022, d1xxx)">
                <FanLevelReg0>52</FanLevelReg0>
                <FanLevelReg1>53</FanLevelReg1>
                <FanRateReadReg0>46</FanRateReadReg0>
                <FanRateReadReg1>47</FanRateReadReg1>
                <FanRateWriteReg0>58</FanRateWriteReg0>
                <FanRateWriteReg1>59</FanRateWriteReg1>
                <FanSpeedReg0>176</FanSpeedReg0>
                <FanSpeedReg1>178</FanSpeedReg1>
                <CountdownReg>99</CountdownReg>
                <ManualReg>98</ManualReg>
                <ModeReg>149</ModeReg>
                <SwitchReg>244</SwitchReg>
            </Model>
            <!-- 8BD4: HP Victus 16-S0053NT (2024) — fan level at 0x11/0x14. -->
            <!-- Single fan controller; both fans run synchronised. Legacy 0xB0/0xB2 RPM offsets are -->
            <!-- repurposed as temperature sensors on this board. The fan tachometer is the level -->
            <!-- register itself, read as byte ×100 RPM (Pattern C / DirectMultiplier8). -->
            <!-- AutoCal.Prime() applies that mapping at platform init; FanSpeedReg0/1 below are -->
            <!-- placeholders kept for the underlying read component constructor. -->
            <Model ProductId="8BD4" DisplayName="HP Victus 16-S0053NT (2024)">
                <FanLevelReg0>17</FanLevelReg0>
                <FanLevelReg1>20</FanLevelReg1>
                <FanRateReadReg0>46</FanRateReadReg0>
                <FanRateReadReg1>47</FanRateReadReg1>
                <FanRateWriteReg0>58</FanRateWriteReg0>
                <FanRateWriteReg1>59</FanRateWriteReg1>
                <FanSpeedReg0>17</FanSpeedReg0>
                <FanSpeedReg1>20</FanSpeedReg1>
                <CountdownReg>99</CountdownReg>
                <ManualReg>98</ManualReg>
                <ModeReg>149</ModeReg>
                <SwitchReg>244</SwitchReg>
            </Model>
            <!-- 8C9C: HP Victus 16 (2024, 1034NF) — fan level at 0x11 (CPU) / 0x12 (GPU). EC[0xB0] and     -->
            <!-- EC[0xB2] are temperature sensors on this board, not RPM tachometers. The single shared    -->
            <!-- fan tachometer is at EC[0xF1]: 8-bit byte × 60 = RPM (e.g. 0x5C=92 → 5520 RPM).         -->
            <!-- AutoCal.Prime() applies the ×60 DirectMultiplier8 mapping at startup. FanSpeedReg0/1     -->
            <!-- below point at 0xF1 so the underlying EcComponent constructor gets a valid address;      -->
            <!-- the actual read is handled by AutoCal. No backlight (HasBacklight=False).                -->
            <Model ProductId="8C9C" DisplayName="HP Victus 16 (2024)">
                <FanLevelReg0>17</FanLevelReg0>
                <FanLevelReg1>18</FanLevelReg1>
                <FanRateReadReg0>46</FanRateReadReg0>
                <FanRateReadReg1>47</FanRateReadReg1>
                <FanRateWriteReg0>58</FanRateWriteReg0>
                <FanRateWriteReg1>59</FanRateWriteReg1>
                <FanSpeedReg0>241</FanSpeedReg0>
                <FanSpeedReg1>241</FanSpeedReg1>
                <CountdownReg>99</CountdownReg>
                <ManualReg>98</ManualReg>
                <ModeReg>149</ModeReg>
                <SwitchReg>244</SwitchReg>
            </Model>
            <!-- 8D07: HP Victus 15 (2024, AMD Ryzen 5 7535HS + RX 6550M) — issue #23, ghend-oss.        -->
            <!-- TENTATIVE — needs gaming-load verification by the issue reporter. From the wizard's EC   -->
            <!-- dumps EC[0x34]/[0x35] (SRP1/SRP2) was the only register pair that monotonically tracked  -->
            <!-- the 0/30/70/100% sweep (00→10→26→26), and EC[0x2C]/[0x2D] (XSS1/XSS2) was the only       -->
            <!-- register pair that ramped with the rate command (00→00→46→46). EC[0x11]/[0x12] (the      -->
            <!-- 2023+ default for FanLevel) sits at a constant 0x58 on this board, and EC[0x3A]/[0x3B]   -->
            <!-- (the 2023+ default for FanRateWrite) stays at 0x00 throughout — both look dead. So this  -->
            <!-- entry uses the classic 2022 layout.                                                       -->
            <!--                                                                                           -->
            <!-- Caveat: the 0x2C/0x2D ramp may actually have come from the BIOS WMI SetFanLevel path      -->
            <!-- writing internally, not from OmenMon's EC writes. If that's the case, switching the      -->
            <!-- FanRateWrite address won't on its own change anything (the WMI path runs the same way).  -->
            <!-- ghend-oss's calibration peaked at ~3789 RPM; if a real 100% command had reached the EC,  -->
            <!-- fans should have hit several thousand more — so either the BIOS-WMI path is rate-limited -->
            <!-- on this SKU, or our writes still aren't taking effect. Validation needed:                 -->
            <!--   1. Update OmenMon to v1.3.3 and re-run the Auto-Calibration Wizard.                    -->
            <!--   2. If the new peak is materially higher (closer to 5000–5500 RPM under sustained load) -->
            <!--      the layout fix worked — please post the new calibration report on issue #23.        -->
            <!--   3. If the peak is still ~3800 RPM, the limit is firmware-side (BIOS clamps fan rate    -->
            <!--      below 100% on this AMD Victus 15 SKU); not something OmenMon can override from EC.  -->
            <!--                                                                                           -->
            <!-- EC[0xB0]/[0xB2] is confirmed 16-bit LE RPM (CPU/GPU) on both calibration runs.            -->
            <!-- DisplayName corrected from "Omen 16" — 8D07 is the AMD Ryzen 5 7535HS + RX 6550M Victus  -->
            <!-- 15, not an Omen.                                                                          -->
            <!--                                                                                           -->
            <!--   FanLevelReg0/1     = 52/53   (0x34/0x35 = SRP1/SRP2)                                    -->
            <!--   FanRateReadReg0/1  = 46/47   (0x2E/0x2F = XGS1/XGS2)                                    -->
            <!--   FanRateWriteReg0/1 = 44/45   (0x2C/0x2D = XSS1/XSS2)                                    -->
            <!--   FanSpeedReg0/1     = 176/178 (0xB0/0xB2 = RPM1/RPM3 — confirmed via wizard)             -->
            <!--   ManualReg/ModeReg/SwitchReg = legacy defaults (98/149/244) — untested on this board.    -->
            <!--   ManualValue overrides not used; if SetManual ends up doing nothing, follow the same    -->
            <!--   diagnosis path as 8BBE (compare hardware probes between Custom-fan and Auto modes).     -->
            <!--     -->
            <Model ProductId="8D07" DisplayName="HP Victus 15 (2024, AMD)">
                <FanLevelReg0>52</FanLevelReg0>
                <FanLevelReg1>53</FanLevelReg1>
                <FanRateReadReg0>46</FanRateReadReg0>
                <FanRateReadReg1>47</FanRateReadReg1>
                <FanRateWriteReg0>44</FanRateWriteReg0>
                <FanRateWriteReg1>45</FanRateWriteReg1>
                <FanSpeedReg0>176</FanSpeedReg0>
                <FanSpeedReg1>178</FanSpeedReg1>
                <CountdownReg>99</CountdownReg>
                <ManualReg>98</ManualReg>
                <ModeReg>149</ModeReg>
                <SwitchReg>244</SwitchReg>
            </Model>
            <!-- 8E71: HP Omen 16-am1000 (2026 BIOS) — confirmed via Auto-Calibration Wizard (issue #22). -->
            <!-- Classic 16-bit LE RPM tachometers at 0xB0/0xB2 (CPU max ~3660, GPU max ~3630 RPM).       -->
            <!-- Fan level at 0x11/0x12, rate write at 0x3A/0x3B — standard 2023+ layout.                 -->
            <Model ProductId="8E71" DisplayName="HP Omen 16-am1000 (2026)">
                <FanLevelReg0>17</FanLevelReg0>
                <FanLevelReg1>18</FanLevelReg1>
                <FanRateReadReg0>46</FanRateReadReg0>
                <FanRateReadReg1>47</FanRateReadReg1>
                <FanRateWriteReg0>58</FanRateWriteReg0>
                <FanRateWriteReg1>59</FanRateWriteReg1>
                <FanSpeedReg0>176</FanSpeedReg0>
                <FanSpeedReg1>178</FanSpeedReg1>
                <CountdownReg>99</CountdownReg>
                <ManualReg>98</ManualReg>
                <ModeReg>149</ModeReg>
                <SwitchReg>244</SwitchReg>
            </Model>
        </Models>
        <!-- Update Interval -->
        <UpdateIconInterval>3</UpdateIconInterval>
        <UpdateMonitorInterval>3</UpdateMonitorInterval>
        <UpdateProgramInterval>15</UpdateProgramInterval>
    </Config>
    <!-- Localizable Messages -->
    <Messages>
        <!-- <String Key="CliTranslated">Translated to [Language] by [Author]</String> -->
        <!-- <String Key="GuiTranslated">Translated by [Author]</String> -->
    </Messages>
</OmenMon>